<h1> Edit  Profile </h1>

<%= form_with(model: @judge, local: true) do |form| %>
  <% if @judge.errors.any? %>
    <div id="error_explanation">
      <h2><%= pluralize(@judge.errors.count, "error") %> prohibited this judge from being saved:</h2>

      <ul>
        <% @judge.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="field">
    <%= form.label :judge_name %>
    <%= form.text_field :judge_name %>
  </div>

    <div class="field">
        <%= form.label :judge_title %>
        <%= form.text_field :judge_title %>
    </div>

  <div class="field">
    <%= form.label :judge_bio %>
    <%= form.text_area :judge_bio %>
  </div>

  <div class="field">
    <%= form.label :judge_photo %>
    <%= form.file_field :judge_photo %>
  </div>

  <div class="field">
    <%= form.label :ideathon %>
    <%= form.select :ideathon, [2026] %>
  </div>

  <div class="actions">
    <%= form.submit "Update Judge" %>
  </div>

  <div class="actions">
    <%= link_to 'Back', judges_path %>
  </div>
  
  <% if @judge.judge_photo.attached? %>
    <%= image_tag @judge.judge_photo, alt: "#{@judge.judge_name}'s photo" %>
  <% else %>
    <p>Default Icon</p>
  <% end %>

<% end %>